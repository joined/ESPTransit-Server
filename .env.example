HAFAS_PROFILE=bvg
PORT=3000
REDIS_URL=redis://localhost:6379
USER_AGENT=esptransit-server/1.0 contact@example.com

# OTLP observability (optional — server runs normally without these)
OBSERVABILITY_ENABLED=true
OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS=

# OpenTelemetry service metadata
OTEL_SERVICE_NAME=esptransit-server
OTEL_SERVICE_NAMESPACE=
OTEL_DEPLOYMENT_ENVIRONMENT=development
OTEL_EXPORT_INTERVAL_MS=15000
OTEL_EXPORT_TIMEOUT_MS=10000
